<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Heavenly Accessories — Clothing, Bags, Shoes, Robes & Jewelry</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>

  /* ===================== DESIGN TOKENS ===================== */
  :root{
    --ink:#241620;
    --ink-2:#3a2436;
    --ink-soft:rgba(36,22,32,.68);
    --ink-faint:rgba(36,22,32,.42);
    --cloud:#FAF6F0;
    --cloud-2:#F2EAE0;
    --paper:#FFFDFB;
    --halo:#C9A24C;
    --halo-light:#E4C77E;
    --halo-dim:rgba(201,162,76,.28);
    --dusk:#8C4F57;
    --dusk-light:#c98d92;
    --blush:#F1DFD6;
    --line:rgba(36,22,32,.12);
    --sale:#A23E4A;

    --display:'Fraunces', serif;
    --body:'Sora', sans-serif;

    --container:1320px;
    --ease: cubic-bezier(.22,.68,.28,1);

    --header-h: 82px;
    --announce-h: 40px;
  }

  *,*::before,*::after{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; scroll-padding-top:120px; }
  body{
    margin:0;
    background:var(--cloud);
    color:var(--ink);
    font-family:var(--body);
    font-weight:400;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  img{ max-width:100%; display:block; }
  a{ color:inherit; text-decoration:none; }
  ul{ list-style:none; margin:0; padding:0; }
  h1,h2,h3,h4{ margin:0; font-family:var(--display); font-weight:500; }
  p{ margin:0; }
  button{ font-family:var(--body); border:none; background:none; cursor:pointer; color:inherit; }
  section{ position:relative; }

  ::selection{ background:var(--halo-dim); color:var(--ink); }
  :focus-visible{ outline:2px solid var(--halo); outline-offset:3px; border-radius:4px; }

  .wrap{ width:100%; max-width:var(--container); margin:0 auto; padding:0 32px; }

  .eyebrow{
    font-family:var(--body); font-size:12.5px; font-weight:600; letter-spacing:.22em;
    text-transform:uppercase; color:var(--dusk);
    display:inline-flex; align-items:center; gap:10px;
  }
  .eyebrow::before{ content:''; width:22px; height:1px; background:var(--halo); }

  .btn{
    position:relative; display:inline-flex; align-items:center; justify-content:center; gap:10px;
    padding:15px 28px; border-radius:2px; font-family:var(--body); font-size:12.5px; font-weight:600;
    letter-spacing:.1em; text-transform:uppercase; cursor:pointer; border:1px solid transparent;
    overflow:hidden; isolation:isolate; transition:transform .4s var(--ease), box-shadow .4s var(--ease), color .3s ease, background .3s ease;
    white-space:nowrap;
  }
  .btn span{ position:relative; z-index:2; display:inline-flex; align-items:center; gap:8px;}
  .btn-primary{ background:var(--ink); color:var(--cloud); }
  .btn-primary::before{
    content:''; position:absolute; inset:0;
    background:linear-gradient(100deg, var(--halo) 0%, var(--halo-light) 45%, var(--halo) 100%);
    transform:translateX(-105%); transition:transform .5s var(--ease); z-index:1;
  }
  .btn-primary:hover{ color:var(--ink); box-shadow:0 14px 32px -14px rgba(201,162,76,.55); transform:translateY(-2px); }
  .btn-primary:hover::before{ transform:translateX(0); }

  .btn-ghost{ background:transparent; color:var(--ink); border:1px solid var(--line); }
  .btn-ghost:hover{ border-color:var(--ink); transform:translateY(-2px); }
  .btn-ghost-light{ background:transparent; color:var(--cloud); border:1px solid rgba(250,246,240,.35); }
  .btn-ghost-light:hover{ border-color:var(--halo-light); color:var(--halo-light); transform:translateY(-2px); }
  .btn-block{ width:100%; }
  .btn-sm{ padding:11px 18px; font-size:11px; }

  /* ===================== REVEAL ===================== */
  .reveal{ opacity:0; transform:translateY(26px); transition:opacity .8s var(--ease), transform .8s var(--ease); }
  .reveal.is-visible{ opacity:1; transform:translateY(0); }
  .reveal-delay-1.is-visible{ transition-delay:.08s; }
  .reveal-delay-2.is-visible{ transition-delay:.16s; }
  .reveal-delay-3.is-visible{ transition-delay:.24s; }
  .reveal-delay-4.is-visible{ transition-delay:.32s; }

  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:.001ms !important; animation-iteration-count:1 !important; transition-duration:.001ms !important; scroll-behavior:auto !important; }
  }

  /* ===================== ANNOUNCEMENT BAR ===================== */
  .announce{
    position:fixed; top:0; left:0; right:0; z-index:120;
    height:var(--announce-h);
    background:var(--ink);
    color:var(--cloud);
    overflow:hidden;
  }
  .announce-track{
    display:flex; align-items:center; height:100%;
    animation:announce-scroll 22s linear infinite;
    width:max-content;
  }
  .announce-track span{
    display:flex; align-items:center; gap:10px;
    font-size:11.5px; font-weight:600; letter-spacing:.09em; text-transform:uppercase;
    padding:0 40px; white-space:nowrap; color:var(--halo-light);
  }
  .announce-track span b{ color:var(--cloud); font-weight:600; }
  .announce-track span::after{ content:'•'; margin-left:40px; color:rgba(250,246,240,.3); }
  @keyframes announce-scroll{ from{ transform:translateX(0); } to{ transform:translateX(-50%); } }

  /* ===================== HEADER ===================== */
  .site-header{
    position:fixed; top:var(--announce-h); left:0; right:0; z-index:110;
    background:var(--cloud); border-bottom:1px solid var(--line);
    transition:box-shadow .4s var(--ease);
  }
  .site-header.scrolled{ box-shadow:0 12px 30px -20px rgba(36,22,32,.4); }
  .header-row{
    display:grid; grid-template-columns:1fr auto 1fr; align-items:center;
    height:var(--header-h); gap:20px;
  }
  .header-left{ display:flex; align-items:center; gap:24px; }
  .menu-toggle{ display:none; align-items:center; justify-content:center; width:34px; height:34px; }
  .menu-toggle span, .menu-toggle span::before, .menu-toggle span::after{
    content:''; display:block; width:20px; height:1.5px; background:var(--ink); position:relative; transition:.3s var(--ease);
  }
  .menu-toggle span::before{ position:absolute; top:-6px; }
  .menu-toggle span::after{ position:absolute; top:6px; }

  .brand{ display:flex; align-items:center; gap:12px; justify-content:center; }
  .brand-mark{ width:32px; height:32px; flex:none; }
  .brand-word{ font-family:var(--display); font-size:19px; letter-spacing:.05em; font-weight:600; text-transform:uppercase; text-align:center; }
  .brand-word small{
    display:block; font-family:var(--body); font-size:9.5px; font-weight:500; letter-spacing:.26em;
    color:var(--dusk); text-transform:uppercase; margin-top:2px;
  }

  .main-nav{ display:flex; align-items:center; gap:2px; }
  .main-nav > li{ position:relative; }
  .main-nav > li > a{
    display:flex; align-items:center; height:var(--header-h); padding:0 16px;
    font-size:12.5px; font-weight:600; letter-spacing:.06em; text-transform:uppercase;
  }
  .main-nav > li > a.is-sale{ color:var(--sale); }
  .main-nav > li::after{
    content:''; position:absolute; left:16px; right:16px; bottom:24px; height:1px;
    background:var(--halo); transform:scaleX(0); transform-origin:left; transition:transform .3s var(--ease);
  }
  .main-nav > li:hover::after{ transform:scaleX(1); }

  .mega{
    position:absolute; top:100%; left:50%; transform:translate(-50%,10px);
    width:560px; background:var(--paper); border:1px solid var(--line); box-shadow:0 30px 60px -30px rgba(36,22,32,.35);
    padding:32px; display:grid; grid-template-columns:1.1fr 1fr; gap:28px;
    opacity:0; pointer-events:none; transition:opacity .3s var(--ease), transform .3s var(--ease);
    z-index:50;
  }
  .main-nav > li:hover .mega{ opacity:1; pointer-events:auto; transform:translate(-50%,0); }
  .mega-figure{ position:relative; border-radius:2px; overflow:hidden; aspect-ratio:4/5; }
  .mega-figure img{ width:100%; height:100%; object-fit:cover; }
  .mega-figure span{
    position:absolute; left:16px; bottom:16px; color:var(--cloud); font-family:var(--display);
    font-size:18px; font-style:italic;
  }
  .mega-links h4{
    font-family:var(--body); font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase;
    color:var(--ink-faint); margin-bottom:14px;
  }
  .mega-links ul{ display:flex; flex-direction:column; gap:11px; margin-bottom:18px; }
  .mega-links a{ font-size:14.5px; }
  .mega-links a:hover{ color:var(--dusk); }
  .mega-links .mega-all{ font-size:12px; font-weight:600; letter-spacing:.05em; text-transform:uppercase; color:var(--ink); border-top:1px solid var(--line); padding-top:14px; display:inline-flex; align-items:center; gap:6px; }

  .header-right{ display:flex; align-items:center; justify-content:flex-end; gap:6px; }
  .icon-btn{
    position:relative; display:flex; align-items:center; justify-content:center;
    width:38px; height:38px; border-radius:50%; transition:background .25s ease;
  }
  .icon-btn:hover{ background:var(--cloud-2); }
  .cart-count{
    position:absolute; top:2px; right:2px; min-width:16px; height:16px; padding:0 3px; border-radius:50%;
    background:var(--dusk); color:var(--cloud); font-size:9.5px; font-weight:700;
    display:flex; align-items:center; justify-content:center; line-height:1;
  }

  /* search flyout */
  .search-flyout{
    position:fixed; top:calc(var(--announce-h) + var(--header-h)); left:0; right:0; z-index:105;
    background:var(--paper); border-bottom:1px solid var(--line);
    padding:0; max-height:0; overflow:hidden; transition:max-height .4s var(--ease), padding .4s var(--ease);
  }
  .search-flyout.open{ max-height:120px; padding:26px 0; }
  .search-flyout form{ display:flex; align-items:center; gap:14px; max-width:640px; margin:0 auto; padding:0 32px; border-bottom:1px solid var(--ink); padding-bottom:10px; }
  .search-flyout input{
    flex:1; border:none; background:none; font-family:var(--display); font-size:22px; font-style:italic; color:var(--ink); outline:none;
  }
  .search-flyout input::placeholder{ color:var(--ink-faint); }

  /* mobile nav drawer */
  .mobile-nav{
    position:fixed; inset:0 auto 0 0; width:min(88vw,380px); background:var(--paper); z-index:200;
    transform:translateX(-100%); transition:transform .4s var(--ease); overflow-y:auto;
    padding:26px 26px 40px;
  }
  .mobile-nav.open{ transform:translateX(0); }
  .mobile-nav-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:26px; }
  .mobile-nav-close{ width:34px; height:34px; display:flex; align-items:center; justify-content:center; }
  .mobile-nav ul{ display:flex; flex-direction:column; }
  .mobile-nav li{ border-bottom:1px solid var(--line); }
  .mobile-nav a{ display:block; padding:16px 2px; font-size:15px; font-weight:600; letter-spacing:.02em; }
  .mobile-nav .m-sub{ padding-left:14px; }
  .mobile-nav .m-sub a{ padding:11px 2px; font-size:13.5px; font-weight:500; color:var(--ink-soft); }

  .scrim{
    position:fixed; inset:0; background:rgba(36,22,32,.4); z-index:190; opacity:0; pointer-events:none;
    transition:opacity .4s var(--ease);
  }
  .scrim.open{ opacity:1; pointer-events:auto; }

  /* ===================== CART DRAWER ===================== */
  .cart-drawer{
    position:fixed; inset:0 0 0 auto; width:min(92vw,420px); background:var(--paper); z-index:210;
    transform:translateX(100%); transition:transform .45s var(--ease);
    display:flex; flex-direction:column;
  }
  .cart-drawer.open{ transform:translateX(0); }
  .cart-head{ display:flex; align-items:center; justify-content:space-between; padding:24px 26px; border-bottom:1px solid var(--line); }
  .cart-head h3{ font-size:19px; }
  .cart-body{ flex:1; overflow-y:auto; padding:10px 26px; }
  .cart-empty{ padding:60px 0; text-align:center; color:var(--ink-soft); }
  .cart-empty svg{ margin:0 auto 16px; opacity:.5; }
  .cart-line{ display:flex; gap:14px; padding:18px 0; border-bottom:1px solid var(--line); }
  .cart-line img{ width:72px; height:88px; object-fit:cover; border-radius:2px; flex:none; }
  .cart-line-body{ flex:1; display:flex; flex-direction:column; gap:4px; }
  .cart-line-top{ display:flex; justify-content:space-between; gap:10px; }
  .cart-line-name{ font-size:13.5px; font-weight:600; }
  .cart-line-cat{ font-size:11px; color:var(--ink-faint); text-transform:uppercase; letter-spacing:.06em; }
  .cart-line-price{ font-size:13px; font-weight:600; white-space:nowrap; }
  .cart-line-actions{ margin-top:auto; display:flex; align-items:center; justify-content:space-between; }
  .qty-stepper{ display:flex; align-items:center; border:1px solid var(--line); border-radius:2px; }
  .qty-stepper button{ width:26px; height:26px; font-size:14px; }
  .qty-stepper span{ min-width:22px; text-align:center; font-size:12.5px; font-weight:600; }
  .cart-remove{ font-size:11px; text-decoration:underline; color:var(--ink-faint); text-transform:uppercase; letter-spacing:.05em; }
  .cart-remove:hover{ color:var(--sale); }
  .cart-foot{ border-top:1px solid var(--line); padding:22px 26px 28px; }
  .cart-subtotal{ display:flex; justify-content:space-between; font-size:15px; font-weight:600; margin-bottom:6px; }
  .cart-note{ font-size:12px; color:var(--ink-soft); margin-bottom:16px; }

  /* toast */
  .toast{
    position:fixed; bottom:26px; left:50%; transform:translateX(-50%) translateY(20px); z-index:250;
    background:var(--ink); color:var(--cloud); padding:14px 22px; border-radius:999px;
    font-size:12.5px; font-weight:600; letter-spacing:.03em; opacity:0; pointer-events:none;
    transition:opacity .35s var(--ease), transform .35s var(--ease);
    display:flex; align-items:center; gap:10px;
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }
  .toast svg{ flex:none; }

  /* ===================== BODY SPACING ===================== */
  .page-shell{ padding-top:calc(var(--announce-h) + var(--header-h)); }

  /* ===================== HERO ===================== */
  .hero{ padding:64px 0 40px; }
  .hero .wrap{ display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center; }
  .hero h1{ font-size:clamp(38px,4.6vw,60px); line-height:1.06; letter-spacing:-.01em; margin:18px 0 20px; }
  .hero h1 em{ font-style:italic; color:var(--dusk); }
  .hero .lede{ font-size:16.5px; color:var(--ink-soft); max-width:460px; margin-bottom:30px; }
  .hero-ctas{ display:flex; gap:14px; flex-wrap:wrap; }
  .hero-visual{ position:relative; border-radius:4px; overflow:hidden; aspect-ratio:4/5; }
  .hero-visual img{ width:100%; height:100%; object-fit:cover; }
  .hero-badge{
    position:absolute; left:20px; top:20px; background:var(--paper); padding:10px 16px; border-radius:2px;
    font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; box-shadow:0 12px 26px -14px rgba(36,22,32,.4);
  }
  .hero-chip{
    position:absolute; right:20px; bottom:20px; left:20px; background:rgba(250,246,240,.94); backdrop-filter:blur(6px);
    padding:18px 20px; border-radius:2px; box-shadow:0 20px 40px -20px rgba(36,22,32,.4);
  }
  .hero-chip p{ font-family:var(--display); font-style:italic; font-size:15.5px; line-height:1.4; }
  .hero-chip .sig{ margin-top:8px; font-family:var(--body); font-style:normal; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--dusk); }

  /* ===================== PERK BAR ===================== */
  .perks{ background:var(--ink); color:var(--cloud); padding:26px 0; }
  .perks .wrap{ display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
  .perk{ display:flex; align-items:center; gap:12px; }
  .perk svg{ flex:none; color:var(--halo-light); }
  .perk b{ display:block; font-size:13px; font-weight:600; }
  .perk span{ display:block; font-size:11.5px; color:rgba(250,246,240,.6); }

  /* ===================== SECTION HEAD ===================== */
  .section-head{ max-width:640px; margin-bottom:44px; }
  .section-head h2{ font-size:clamp(28px,3.2vw,40px); margin:14px 0 12px; }
  .section-head h2 em{ font-style:italic; color:var(--dusk); }
  .section-head p{ color:var(--ink-soft); font-size:15.5px; }
  .section-head-row{ display:flex; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:36px; }
  .section-head-row .section-head{ margin-bottom:0; }
  .view-all{ font-size:12.5px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; white-space:nowrap; display:inline-flex; align-items:center; gap:6px; border-bottom:1px solid var(--ink); padding-bottom:3px; }

  /* ===================== CATEGORY TILES ===================== */
  .categories{ padding:70px 0 20px; }
  .cat-strip{ display:grid; grid-template-columns:repeat(5,1fr); gap:16px; }
  .cat-tile{ position:relative; border-radius:3px; overflow:hidden; aspect-ratio:3/4; }
  .cat-tile img{ width:100%; height:100%; object-fit:cover; transition:transform .6s var(--ease); }
  .cat-tile:hover img{ transform:scale(1.06); }
  .cat-tile::after{ content:''; position:absolute; inset:0; background:linear-gradient(180deg, rgba(36,22,32,0) 40%, rgba(36,22,32,.72) 100%); }
  .cat-tile-label{ position:absolute; left:0; right:0; bottom:0; padding:18px; z-index:2; color:var(--cloud); }
  .cat-tile-label h3{ font-size:18px; margin-bottom:2px; }
  .cat-tile-label span{ font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:rgba(250,246,240,.75); }

  /* ===================== PRODUCT GRID ===================== */
  .shop-section{ padding:64px 0; }
  .shop-section:nth-of-type(even){ background:var(--cloud-2); }
  .product-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:24px; }
  .product-card{ display:flex; flex-direction:column; }
  .product-figure{ position:relative; border-radius:2px; overflow:hidden; aspect-ratio:3/4; background:var(--blush); margin-bottom:14px; }
  .product-figure img{ width:100%; height:100%; object-fit:cover; transition:transform .6s var(--ease); }
  .product-card:hover .product-figure img{ transform:scale(1.045); }
  .product-badge{
    position:absolute; left:12px; top:12px; padding:6px 11px; border-radius:2px; font-size:10px; font-weight:700;
    letter-spacing:.08em; text-transform:uppercase; background:var(--ink); color:var(--cloud);
  }
  .product-badge.sale{ background:var(--sale); }
  .wishlist-btn{
    position:absolute; right:10px; top:10px; width:32px; height:32px; border-radius:50%; background:rgba(250,246,240,.92);
    display:flex; align-items:center; justify-content:center; transition:transform .25s var(--ease);
  }
  .wishlist-btn:hover{ transform:scale(1.08); }
  .wishlist-btn svg{ transition:fill .2s ease, stroke .2s ease; }
  .wishlist-btn.active svg{ fill:var(--dusk); stroke:var(--dusk); }
  .quick-add{
    position:absolute; left:10px; right:10px; bottom:10px; opacity:0; transform:translateY(8px);
    transition:opacity .3s var(--ease), transform .3s var(--ease);
  }
  .product-card:hover .quick-add{ opacity:1; transform:translateY(0); }
  .quick-add button{
    width:100%; background:var(--ink); color:var(--cloud); padding:12px; font-size:11.5px; font-weight:700;
    letter-spacing:.08em; text-transform:uppercase; border-radius:2px; display:flex; align-items:center; justify-content:center; gap:8px;
    transition:background .25s ease;
  }
  .quick-add button:hover{ background:var(--dusk); }
  .product-kicker{ font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--dusk); margin-bottom:4px; }
  .product-name{ font-size:15px; font-weight:600; margin-bottom:5px; }
  .product-price{ display:flex; align-items:center; gap:8px; font-size:14px; font-weight:600; }
  .product-price .was{ text-decoration:line-through; color:var(--ink-faint); font-weight:400; font-size:13px; }
  .product-price .now.sale{ color:var(--sale); }
  .product-stars{ display:flex; align-items:center; gap:5px; margin-top:6px; }
  .product-stars svg{ color:var(--halo); }
  .product-stars span{ font-size:11px; color:var(--ink-faint); }

  /* ===================== ABOUT ===================== */
  .about{ padding:96px 0; }
  .about .wrap{ display:grid; grid-template-columns:.85fr 1fr; gap:64px; align-items:center; }
  .about-figure{ position:relative; }
  .about-figure img{ width:100%; border-radius:4px; aspect-ratio:4/5; object-fit:cover; }
  .about-badge{
    position:absolute; right:-18px; bottom:-18px; background:var(--ink); color:var(--halo-light); width:112px; height:112px;
    border-radius:50%; display:flex; align-items:center; justify-content:center; text-align:center; font-family:var(--display);
    font-size:13px; font-style:italic; line-height:1.35; box-shadow:0 20px 40px -18px rgba(36,22,32,.5);
  }
  .about-copy h2{ font-size:clamp(28px,3.2vw,38px); margin:14px 0 18px; }
  .about-copy h2 em{ font-style:italic; color:var(--dusk); }
  .body-lg{ font-size:15.5px; color:var(--ink-soft); margin-bottom:16px; }
